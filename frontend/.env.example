APP_NAME="CareerTalent AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Laravel yalnızca oturum/cache için SQLite kullanır; iş verisi FastAPI'de
DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=database

# FastAPI backend adresi
CAREERTALENT_API_URL=http://localhost:8000

# Sunucu tarafı CV PDF üretimi
LARAVEL_PDF_DRIVER=chrome
LARAVEL_PDF_CHROME_BINARY=/usr/bin/google-chrome
# Kullanıcı namespace'i kapalı production sunucularında true olmalıdır.
LARAVEL_PDF_CHROME_NO_SANDBOX=false

VITE_APP_NAME="${APP_NAME}"
